cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# THEME

theme = One Dark
bold-color = bright

# custom-shader = ~/.config/ghostty/shaders/cursor_blaze.glsl
# custom-shader = ~/.config/ghostty/shaders/cursor_frozen.glsl
# custom-shader = ~/.config/ghostty/shaders/cursor_blaze_no_trail.glsl

# FONT

# font-family = "Monaco"
font-size = 14
font-thicken = true
# font-thicken-strength = 128

# WINDOW

window-width = 145
window-height = 40

window-inherit-working-directory = true

keybind = shift+enter=text:\n

