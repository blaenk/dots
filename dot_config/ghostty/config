cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

theme = One Dark
bold-color = bright

font-family = "Monaco"
font-size = 14
font-thicken = true
# font-thicken-strength = 128

window-width = 145
window-height = 40

custom-shader = ~/.config/ghostty/shaders/cursor_blaze.glsl
# custom-shader = ~/.config/ghostty/shaders/cursor_frozen.glsl
# custom-shader = ~/.config/ghostty/shaders/cursor_blaze_no_trail.glsl

window-inherit-working-directory = true
